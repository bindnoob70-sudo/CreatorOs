# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=creatoros_db
DATABASE_USER=creatoros_user
DATABASE_PASSWORD=secure-password-change-this
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@creatoros.com

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# YouTube OAuth
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/channels/oauth/callback/

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/

# AWS S3 (Optional - for production file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Media Files
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Static Files
STATIC_ROOT=/app/static
STATIC_URL=/static/

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/creatoros.log

# API Settings
API_VERSION=v1
API_RATE_LIMIT=100/hour

# Frontend Settings
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENVIRONMENT=development

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True

# Feature Flags
FEATURE_TREND_ENGINE=True
FEATURE_SCRIPT_GENERATOR=True
FEATURE_SEO_GENERATOR=True
FEATURE_THUMBNAIL_GENERATOR=True
FEATURE_VIDEO_GENERATOR=True
FEATURE_VOICE_ENGINE=True
FEATURE_GROWTH_AGENT=True

# Monitoring & Analytics
SENTRY_DSN=
MIXPANEL_TOKEN=

# Development
DEBUG_TOOLBAR=False
DEBUG_SQL_QUERIES=False
